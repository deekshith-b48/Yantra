# ─── Frontend (Vercel) ────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_here
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Backend (Railway / local) ────────────────────────────────────────────────
DATABASE_URL=postgresql://yantra:yantra_dev@localhost:5432/yantra
REDIS_URL=redis://localhost:6379

ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here


# 32-byte random hex — generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PATH=/data/chroma

# GitHub App (optional — uses user token by default)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# Docker (used by sandbox.py)
DOCKER_HOST=unix:///var/run/docker.sock

# API settings
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development


